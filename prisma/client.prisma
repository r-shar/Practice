model Client {
  id          String   @id @default(cuid())

  therapistId String
  therapist   Therapist @relation(fields: [therapistId], references: [id])

  firstName   String
  lastName    String
  email       String?
  phone       String?

  appointments AppointmentParticipant[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}